SYZM_ENV=dev
SYZM_MODEL_URI=models/latest.json
SYZM_DEFAULT_RETRY_DELAY_MINUTES=90
SYZM_MAX_RETRIES=4
SYZM_TIMEZONE=America/New_York
SYZM_SUPABASE_URL=https://your-project.supabase.co
SYZM_SUPABASE_SERVICE_ROLE_KEY=replace-me
SYZM_BRAIN_URL=http://localhost:8080
SYZM_STRIPE_API_KEY=replace-me
SYZM_ADYEN_API_KEY=replace-me
SYZM_BRAINTREE_API_KEY=replace-me

# Brain scoring API auth — ingest must send this as X-Syzm-Key on every call
SYZM_BRAIN_API_KEY=replace-me

# Webhook signature verification (ingest layer)
SYZM_STRIPE_WEBHOOK_SECRET=replace-me
SYZM_ADYEN_HMAC_KEY=replace-me
SYZM_ADYEN_MERCHANT_ACCOUNT=replace-me
SYZM_BRAINTREE_PUBLIC_KEY=replace-me
SYZM_BRAINTREE_PRIVATE_KEY=replace-me
SYZM_BRAINTREE_MERCHANT_ID=replace-me

# Portal (Next.js) — NEXT_PUBLIC_ prefix is required by Next for client-readable values
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=replace-me
